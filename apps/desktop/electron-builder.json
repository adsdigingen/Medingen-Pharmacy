{
  "appId": "com.medingen.pharmacy",
  "productName": "Medingen Pharmacy",
  "directories": {
    "output": "dist-installer",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "renderer/out/**/*",
    "server/dist/**/*",
    "node_modules/**/*",
    "package.json",
    {
      "from": "../../node_modules/.prisma",
      "to": "node_modules/.prisma"
    },
    {
      "from": "../../node_modules/@medingen",
      "to": "node_modules/@medingen"
    }
  ],
  "asar": true,
  "asarUnpack": [
    "server/dist/**",
    "**/node_modules/.prisma/**",
    "**/node_modules/@prisma/**",
    "**/node_modules/prisma/**",
    "**/node_modules/@medingen/**",
    "**/node_modules/@nestjs/**",
    "**/node_modules/rxjs/**",
    "**/node_modules/reflect-metadata/**",
    "**/node_modules/bcryptjs/**",
    "**/node_modules/class-transformer/**",
    "**/node_modules/class-validator/**",
    "**/node_modules/express/**",
    "**/node_modules/uuid/**",
    "**/node_modules/xlsx/**",
    "**/node_modules/@nestjs-modules/**",
    "**/node_modules/pg/**",
    "**/node_modules/pg-pool/**",
    "**/node_modules/pg-protocol/**",
    "**/node_modules/pg-types/**"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": true,
    "allowToChangeInstallationDirectory": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "runAfterFinish": true,
    "shortcutName": "Medingen Pharmacy"
  }
}
